#!/usr/bin/env python3
"""
NexusOS CLI - Command-line interface for Nexus AI
"""

import os
import sys
import json
import argparse
import requests
from typing import Optional

# Configuration
API_BASE = os.environ.get('NEXUSOS_API', 'http://localhost:8080')
API_KEY = os.environ.get('NEXUSOS_API_KEY', '')

# Token file for persistence
TOKEN_FILE = os.path.expanduser('~/.nexusos_token')

def load_token():
    """Load token from file"""
    if os.path.exists(TOKEN_FILE):
        with open(TOKEN_FILE) as f:
            return f.read().strip()
    return None

def save_token(token):
    """Save token to file"""
    with open(TOKEN_FILE, 'w') as f:
        f.write(token)

def get_headers():
    """Get headers for API requests"""
    headers = {'Content-Type': 'application/json'}
    token = API_KEY or load_token()
    if token:
        headers['Authorization'] = f'Bearer {token}'
    return headers

def cmd_status(args):
    """Check system status"""
    r = requests.get(f'{API_BASE}/api/status', headers=get_headers())
    print(json.dumps(r.json(), indent=2))

def cmd_agents(args):
    """List agents"""
    r = requests.get(f'{API_BASE}/api/agents', headers=get_headers())
    data = r.json()
    if args.json:
        print(json.dumps(data, indent=2))
    else:
        for a in data.get('agents', []):
            print(f"{a['id']}: {a['name']} [{a['status']}]")

def cmd_agent_create(args):
    """Create a new agent"""
    payload = {
        'name': args.name,
        'description': args.description or '',
        'model': args.model or 'phi3',
        'system_prompt': args.system_prompt or '',
        'tools': args.tools.split(',') if args.tools else [],
    }
    r = requests.post(f'{API_BASE}/api/agents', json=payload, headers=get_headers())
    data = r.json()
    if r.status_code == 200 or r.status_code == 201:
        print(f"✅ Agent created: {data.get('id')}")
    else:
        print(f"❌ Error: {data}")
        sys.exit(1)

def cmd_agent_start(args):
    """Start an agent"""
    r = requests.post(f'{API_BASE}/api/agents/{args.agent_id}/start', headers=get_headers())
    if r.status_code == 200:
        print(f"✅ Agent {args.agent_id} started")
    else:
        print(f"❌ Error: {r.json()}")
        sys.exit(1)

def cmd_agent_stop(args):
    """Stop an agent"""
    r = requests.post(f'{API_BASE}/api/agents/{args.agent_id}/stop', headers=get_headers())
    if r.status_code == 200:
        print(f"✅ Agent {args.agent_id} stopped")
    else:
        print(f"❌ Error: {r.json()}")
        sys.exit(1)

def cmd_chat(args):
    """Send a chat message"""
    payload = {'message': args.message}
    if args.agent:
        payload['agent_id'] = args.agent
    
    r = requests.post(f'{API_BASE}/api/chat', json=payload, headers=get_headers())
    data = r.json()
    print(data.get('response', data.get('message', 'No response')))

def cmd_logs(args):
    """Get audit logs"""
    params = {'limit': args.limit}
    r = requests.get(f'{API_BASE}/api/logs', params=params, headers=get_headers())
    data = r.json()
    if args.json:
        print(json.dumps(data, indent=2))
    else:
        for log in data.get('logs', []):
            print(f"[{log['timestamp']}] {log['level']}: {log['message']}")

def cmd_backup(args):
    """Create or list backups"""
    if args.list:
        r = requests.get(f'{API_BASE}/api/backup', headers=get_headers())
        for b in r.json().get('backups', []):
            print(f"{b['created']}: {b['file']} ({b['size']} bytes)")
    else:
        r = requests.post(f'{API_BASE}/api/backup', headers=get_headers())
        data = r.json()
        if data.get('status') == 'success':
            print(f"✅ Backup created: {data.get('backup_file')}")
        else:
            print(f"❌ Error: {data}")

def cmd_metrics(args):
    """Get system metrics"""
    r = requests.get(f'{API_BASE}/api/metrics', headers=get_headers())
    print(json.dumps(r.json(), indent=2))

def cmd_login(args):
    """Login and save token"""
    r = requests.post(f'{API_BASE}/api/auth/login', json={
        'email': args.email,
        'password': args.password
    })
    data = r.json()
    if 'access_token' in data:
        save_token(data['access_token'])
        print("✅ Logged in successfully")
    else:
        print(f"❌ Login failed: {data}")
        sys.exit(1)

def main():
    global API_BASE, API_KEY
    parser = argparse.ArgumentParser(description='NexusOS CLI')
    parser.add_argument('--api', default=API_BASE, help='API base URL')
    parser.add_argument('--key', default=API_KEY, help='API key')
    
    sub = parser.add_subparsers(dest='cmd')
    
    # status
    sub.add_parser('status', help='Check system status')
    
    # agents
    agents = sub.add_parser('agents', help='List agents')
    agents.add_argument('--json', action='store_true', help='JSON output')
    
    create = sub.add_parser('agent-create', help='Create an agent')
    create.add_argument('--name', required=True, help='Agent name')
    create.add_argument('--description', help='Agent description')
    create.add_argument('--model', default='phi3', help='Model to use')
    create.add_argument('--system-prompt', default='', help='System prompt')
    create.add_argument('--tools', default='', help='Comma-separated tools')
    
    start = sub.add_parser('agent-start', help='Start an agent')
    start.add_argument('agent_id', help='Agent ID')
    
    stop = sub.add_parser('agent-stop', help='Stop an agent')
    stop.add_argument('agent_id', help='Agent ID')
    
    # chat
    chat = sub.add_parser('chat', help='Send a chat message')
    chat.add_argument('message', help='Message to send')
    chat.add_argument('--agent', help='Agent ID to use')
    
    # logs
    logs = sub.add_parser('logs', help='Get audit logs')
    logs.add_argument('--limit', type=int, default=10, help='Number of logs')
    logs.add_argument('--json', action='store_true', help='JSON output')
    
    # backup
    backup = sub.add_parser('backup', help='Manage backups')
    backup.add_argument('--list', action='store_true', help='List backups')
    
    # metrics
    sub.add_parser('metrics', help='Get system metrics')
    
    # login
    login = sub.add_parser('login', help='Login to NexusOS')
    login.add_argument('--email', required=True, help='Email')
    login.add_argument('--password', required=True, help='Password')
    
    args = parser.parse_args()
    
    # Override API base if provided
    API_BASE = args.api
    API_KEY = args.key
    
    if args.cmd == 'status':
        cmd_status(args)
    elif args.cmd == 'agents':
        cmd_agents(args)
    elif args.cmd == 'agent-create':
        cmd_agent_create(args)
    elif args.cmd == 'agent-start':
        cmd_agent_start(args)
    elif args.cmd == 'agent-stop':
        cmd_agent_stop(args)
    elif args.cmd == 'chat':
        cmd_chat(args)
    elif args.cmd == 'logs':
        cmd_logs(args)
    elif args.cmd == 'backup':
        cmd_backup(args)
    elif args.cmd == 'metrics':
        cmd_metrics(args)
    elif args.cmd == 'login':
        cmd_login(args)
    else:
        parser.print_help()

if __name__ == '__main__':
    main()
