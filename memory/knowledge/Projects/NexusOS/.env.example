# NexusOS Environment Variables
# Copy this file to .env and fill in your values

# ============ LLM Providers ============
# Get your API key from https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_key_here

# Optional: Anthropic for Claude (fallback)
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional: OpenAI
# OPENAI_API_KEY=your_openai_key_here

# ============ Messaging Channels ============
# Telegram - get from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ALLOWED_USER=8643045688

# Discord - create a bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=your_guild_id

# Email - IMAP/SMTP settings
IMAP_HOST=imap.gmail.com
IMAP_USERNAME=your_email@gmail.com
IMAP_PASSWORD=your_app_password
SMTP_HOST=smtp.gmail.com
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ============ Voice (TTS) ============
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=your_preferred_voice

# ============ Security ============
WEBHOOK_AUTH=random_string_for_webhook_verification

# ============ Configuration ============
NEXUS_ENV=production
NEXUS_MEMORY_DRIVER=lancedb